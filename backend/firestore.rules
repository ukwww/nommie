rules_version = '2';

// Nommie Firestore security rules.
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // User profiles — readable by any signed-in user (feed, QR, profile lookup).
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId)
                    && request.resource.data.uid == userId;
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    // Recipes — readable by any signed-in user (global feed, profile, detail).
    match /recipes/{recipeId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
                    && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn()
                    && resource.data.userId == request.auth.uid;
    }

    // Follows — doc ID is "{followerId}_{followingId}".
    match /follows/{followId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
                    && request.resource.data.followerId == request.auth.uid;
      allow delete: if isSignedIn()
                    && resource.data.followerId == request.auth.uid;
    }

    // Saved recipes — doc ID is "{userId}_{recipeId}".
    match /saved/{savedId} {
      allow read: if isSignedIn()
                  && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn()
                    && request.resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn()
                    && resource.data.userId == request.auth.uid;
    }
  }
}
