rules_version = '2';

// Nommie Storage security rules.
// Recipe photos live at recipe_images/{recipeId}.jpg and are fetched by the
// app via tokened download URLs, so client SDK reads stay auth-gated.
service firebase.storage {
  match /b/{bucket}/o {
    match /recipe_images/{imageFile} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType == 'image/jpeg';
      allow delete: if request.auth != null;
    }

    // Profile avatars — users may only write their own file.
    match /profile_images/{imageFile} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && imageFile == request.auth.uid + '.jpg'
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType == 'image/jpeg';
      allow delete: if request.auth != null
                    && imageFile == request.auth.uid + '.jpg';
    }

    // Everything else is locked down.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
